{
  "name": "mason/libqueuex",
  "description": "FlexQueue package test tooling",
  "type": "project",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6"
  },
  "autoload": {
    "psr-4": {
      "Mason\\FlexQueue\\": "lib_flexqueue/src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/unit/"
    }
  },
  "scripts": {
    "test:unit": "phpunit -c phpunit.xml.dist"
  }
}
