<?xml version="1.0"?>
<ruleset name="FlexQueue">
	<description>PSR12, but without line length check.</description>
	<rule ref="PSR12">
		<exclude name="Generic.Files.LineLength"/>
	</rule>
    <!-- Add custom rule for short array syntax -->
    <rule ref="Generic.Arrays.DisallowLongArraySyntax"/>
    <exclude name="Squiz.Commenting.FunctionComment"/>
</ruleset>