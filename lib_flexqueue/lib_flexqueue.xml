<?xml version="1.0" encoding="utf-8"?>
<extension type="library" method="upgrade">
    <name>FlexQueue</name>
    <libraryname>lib_flexqueue</libraryname>
    <version>0.1.3</version>
    <author>Mason</author>
    <creationDate>2025-10-25</creationDate>
    <description>Pluggable queue library for Joomla.</description>
    <namespace path="src">Mason\FlexQueue</namespace>

    <files>
        <folder>src</folder>
        <folder>sql</folder>
        <file>autoload.php</file>
    </files>

    <scriptfile>scripts/install.php</scriptfile>
    <install>
        <sql>
            <file driver="mysql" charset="utf8">sql/install.sql</file>
        </sql>
    </install>
    <update>
        <schemas>
            <schemapath type="mysql">sql/updates/mysql</schemapath>
        </schemas>
    </update>
</extension>

